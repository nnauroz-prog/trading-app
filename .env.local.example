# Supabase (server-side persistence). Lasse beides leer, um im Mock-Modus zu laufen.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pflicht in Production: schützt /api/cron/daily-report.
# Erzeugen mit z. B. `openssl rand -hex 32`. Im Dev darf der Wert leer sein.
CRON_SECRET=

# Optional: CoinGecko Demo API Key. Ohne Key wird die öffentliche Free-API genutzt.
COINGECKO_API_KEY=

# Reserviert für spätere Stock-/News-Provider.
FINNHUB_API_KEY=
NEWS_API_KEY=
