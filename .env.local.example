# Supabase (server-side persistence + Auth). Lasse alle drei leer, um im
# Mock-Modus ohne Auth-Gate zu laufen.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Single-User-Login: nur diese E-Mail-Adresse darf nach Magic-Link-Auth ins
# Dashboard. Andere User werden direkt abgemeldet. Leer = jeder, der den
# Magic Link erhält, kommt rein (für Tests).
ALLOWED_EMAIL=

# Pflicht in Production: schützt /api/cron/daily-report.
# Erzeugen mit z. B. `openssl rand -hex 32`. Im Dev darf der Wert leer sein.
CRON_SECRET=

# Optional: CoinGecko Demo API Key. Ohne Key wird die öffentliche Free-API genutzt.
COINGECKO_API_KEY=

# Aktien-Preise + Company-News-Sentiment via Finnhub. Ohne Key bleiben Aktien
# auf Mock und Sentiment auf dem Default-Wert.
FINNHUB_API_KEY=

# Reserviert für zusätzliche News-Provider.
NEWS_API_KEY=
